{
  "name": "handoffos-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "HandoffOS MCP server for enterprise workflow intelligence",
  "scripts": {
    "dev": "mkdir -p src/widgets/.next && nitrostack-cli dev",
    "build": "nitrostack-cli build",
    "test": "npm run build && node --test tests/**/*.test.mjs",
    "start": "npm run build && nitrostack-cli start",
    "start:prod": "nitrostack-cli start",
    "upgrade": "nitrostack-cli upgrade",
    "install:all": "nitrostack-cli install",
    "widget": "npm --prefix src/widgets"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": ">=0.1.0",
    "@nitrostack/core": "^1.0.13",
    "@nitrostack/widgets": "^1.0.8",
    "dotenv": "^16.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nitrostack/cli": "^1.0.14",
    "@types/node": "^22.10.0",
    "tsx": "^4.23.1",
    "typescript": "^5.3.3"
  }
}
